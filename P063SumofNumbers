import java.util.*;
public class P063SumofNumbers
{ public static void main(String[]args){
   int i=0;
   int sumOfNumbers=0;
   for(i=0;i<=99;i++){
       sumOfNumbers=sumOfNumbers+(i+1);
   }System.out.println(sumOfNumbers);
}
}
