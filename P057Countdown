/**
 * Program to count down from 10 to 1 and print "Blast off!"
 *
 * Author: Nakshatra Pradeep
 * Date: 16 July 2026
 */

public class P057
{
    public static void main(String[] args)
    {
        for (int i = 10; i >= 1; i--)
        {
            System.out.println(i);
        }

        System.out.println("Blast off!");
    }
}
