import java.util.*;

public class P019SubString
{
    public static void main(String[] args)
    {
        Scanner kbReader = new Scanner(System.in);

        System.out.print("Enter a word: ");
        String word=kbReader.next();
        System.out.println(word.substring(0,3));
        
        
        
}
}
