import java.util.*;

public class P027InchesConversion
{
    public static void main(String[] args)
    {
        Scanner kbReader = new Scanner(System.in);
        System.out.println("Enter a number of inches:");
        float inches=kbReader.nextInt();
        float feet=inches/12;
        System.out.println("Converted to feet:"+" "+feet+".");
        


        

        


        
}
}
